{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bugbuster",
  "version": "0.6.0",
  "identifier": "com.bugbuster",
  "build": {
    "beforeDevCommand": {
      "script": "trunk serve",
      "cwd": ".."
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "script": "trunk build",
      "cwd": ".."
    },
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BugBuster",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
