[submodule "Firmware/RP2040/lib/pico-sdk"]
	path = Firmware/RP2040/lib/pico-sdk
	url = https://github.com/raspberrypi/pico-sdk.git
[submodule "Firmware/RP2040/lib/debugprobe"]
	path = Firmware/RP2040/lib/debugprobe
	url = https://github.com/raspberrypi/debugprobe.git
[submodule "Firmware/RP2040/lib/tinyusb"]
	path = Firmware/RP2040/lib/tinyusb
	url = https://github.com/lollokara/tinyusb.git
[submodule "Firmware/ESP32/components/micropython/micropython"]
	path = Firmware/ESP32/components/micropython/micropython
	url = https://github.com/micropython/micropython.git
	ignore = untracked
