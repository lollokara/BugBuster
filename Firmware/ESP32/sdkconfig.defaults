# ESP-IDF SDK Configuration for BugBuster AD74416H Controller

# Console: NONE - we handle USB CDC ourselves via TinyUSB
# CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG is not set
# CONFIG_ESP_CONSOLE_USB_CDC is not set
CONFIG_ESP_CONSOLE_NONE=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y

# TinyUSB: dual CDC (CLI + UART bridge), pinned to Core 0 (with WiFi/network)
# Frees Core 1 for real-time SPI measurement tasks
CONFIG_TINYUSB=y
CONFIG_TINYUSB_CDC_ENABLED=y
CONFIG_TINYUSB_CDC_COUNT=2
CONFIG_TINYUSB_TASK_AFFINITY_CPU0=y
CONFIG_TINYUSB_TASK_AFFINITY=0x0

# SPIFFS support
CONFIG_SPIFFS_MAX_PARTITIONS=3

# OTA rollback: if new firmware crashes before confirming, bootloader reverts
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Log level
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# SPI flash — ESP32-S3 N16R8 module: 16 MB flash + 8 MB octal PSRAM
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# Octal PSRAM (AP_Memory APS6408L-OBM or compatible, 64 Mb = 8 MB)
CONFIG_ESP32S3_SPIRAM_SUPPORT=y
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_TYPE_AUTO=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_MEMTEST=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
# Small allocations stay in internal SRAM (fast path); large blocks spill to PSRAM.
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768

# Cache: bump with octal PSRAM (default 16 KB/32 KB is too small for external RAM workloads)
CONFIG_ESP32S3_INSTRUCTION_CACHE_32KB=y
CONFIG_ESP32S3_DATA_CACHE_64KB=y

# LWIP: raise socket limit so the httpd can open max_open_sockets=10 connections.
# httpd reserves 3 sockets internally; 10 + 3 = 13, so 16 gives comfortable headroom.
# Default LWIP_MAX_SOCKETS=7 is too small for SSE streaming + concurrent REST polls.
CONFIG_LWIP_MAX_SOCKETS=16
